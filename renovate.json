{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": ["custom.regex"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/\\.claude/skills/.+/SKILL\\.md$/"],
      "matchStrings": [
        "renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) currentValue=(?<currentValue>\\S+) currentDigest=(?<currentDigest>[a-f0-9]+)"
      ]
    }
  ]
}
